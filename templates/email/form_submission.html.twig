{% extends '@Shared/email/layout/base.html.twig' %}

{% block content %}
<h1>{{ 'editorial.mail.form.admin_heading'|trans }}</h1>
<p>{{ 'editorial.mail.form.admin_intro'|trans({'{title}': formTitle}) }}</p>

<table class="panel" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel-content">
            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="font-size:14px;">
                {% for row in rows %}
                <tr>
                    <td style="padding:6px 12px;font-weight:600;border-bottom:1px solid #eee;">{{ row.label }}</td>
                    <td style="padding:6px 12px;border-bottom:1px solid #eee;">{{ row.value }}</td>
                </tr>
                {% endfor %}
            </table>
        </td>
    </tr>
</table>
{% endblock %}
