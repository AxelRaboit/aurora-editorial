{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.taxonomies'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.editorial'|trans},
            {label: 'backend.nav.taxonomies'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('editorial/backend/taxonomies/TaxonomiesApp', {
    taxonomies: taxonomies,
    postTypes: postTypes,
    locales: locales,
    createPath: path('backend_editorial_taxonomies_create'),
    updatePath: path('backend_editorial_taxonomies_update', {id: '__id__'}),
    deletePath: path('backend_editorial_taxonomies_delete', {id: '__id__'}),
    termCreatePath: path('backend_editorial_taxonomies_term_create', {id: '__id__'}),
    termEditPath: path('backend_editorial_taxonomies_term_edit', {id: '__id__', termId: '__termId__'}),
    termDeletePath: path('backend_editorial_taxonomies_term_delete', {id: '__id__', termId: '__termId__'}),
    termReorderPath: path('backend_editorial_taxonomies_term_reorder', {id: '__id__'}),
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
