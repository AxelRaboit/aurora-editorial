{% extends '@Core/backend/layout.html.twig' %}

{% block title %}{{ 'backend.nav.comments'|trans }} - {{ parent() }}{% endblock %}

{% block page_header_slot %}
    {{ include('@Shared/components/page_header.html.twig', {
        crumbs: [
            {label: 'backend.nav.sections.editorial'|trans},
            {label: 'backend.nav.comments'|trans},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('editorial/backend/comments/CommentsApp', {
    listPath: path('backend_editorial_comments_list'),
    approvePath: path('backend_editorial_comments_approve', {id: '__id__'}),
    spamPath: path('backend_editorial_comments_spam', {id: '__id__'}),
    deletePath: path('backend_editorial_comments_delete', {id: '__id__'}),
    toggleModerationPath: path('backend_editorial_comments_toggle_moderation'),
    stats: stats,
    moderationEnabled: moderationEnabled,
}) }} class="flex-1 min-w-0"></div>
{% endblock %}
